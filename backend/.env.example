# tailBale environment configuration
# Copy to .env and fill in your values.

# ── Auth ──────────────────────────────────────────────────────────────
# JWT signing secret is auto-generated on first startup and stored in
# DATA_DIR/secrets/.jwt_secret. No manual configuration needed.

# How long login sessions last (hours). Default: 24
JWT_EXPIRY_HOURS=24

# Set to true when running behind HTTPS (e.g. Tailscale HTTPS or reverse proxy)
COOKIE_SECURE=false

# Login brute-force protection. After this many consecutive failed logins from a
# client, further attempts are rejected with HTTP 429 for the lockout window
# below; a successful login resets the count. Defaults: 5 failures / 60 seconds.
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_SECONDS=60

# Comma-separated allowed origins for split-origin deployments.
# Leave empty for same-origin/proxied deployments. Use "*" only for
# non-credentialed development requests; cookie auth requires explicit origins.
CORS_ORIGINS=

# ── Server ────────────────────────────────────────────────────────────
# Listen address/port INSIDE the container. Leave HOST=0.0.0.0 — Docker
# forwards the published port to the container over its own interface.
HOST=0.0.0.0
PORT=8080

# Host interface the published port binds to (Compose/redeploy.sh/deploy.sh).
# Loopback by default so the Docker-root admin UI is never exposed in cleartext
# on the LAN. Reach it over your tailnet with `tailscale serve` (HTTPS), or set
# this to your tailnet IP (e.g. 100.x.y.z) for direct http://<tailnet-ip>:HOST_PORT.
# Use 0.0.0.0 only if you deliberately want it on every host interface.
BIND_ADDR=127.0.0.1

# Host port the admin UI is published on (Compose/redeploy.sh/deploy.sh). The
# full published mapping is BIND_ADDR:HOST_PORT -> container PORT, so you reach
# the UI at http://<host-or-tailnet-ip>:HOST_PORT (default http://localhost:6780).
HOST_PORT=6780

# ── Paths ─────────────────────────────────────────────────────────────
# Directory for database, secrets, certs, generated configs, tailscale state.
# In Docker this is the mounted volume.
DATA_DIR=/data

# Absolute path to the data directory ON THE DOCKER HOST. Required for Compose
# and manual `docker run` deploys: the orchestrator creates edge containers via
# the Docker socket, and Docker resolves bind-mount sources on the host, not
# inside this container. `deploy.sh` auto-detects it; Compose requires it set
# explicitly. Leave unset for non-containerised local runs (falls back to DATA_DIR).
HOST_DATA_DIR=/opt/tailbale/data

# Docker socket path. NOTE: read by Compose/redeploy.sh/deploy.sh to mount the
# socket — the orchestrator itself does NOT read this from the environment; its
# effective socket is configured in the in-app setup wizard (stored in the DB).
DOCKER_SOCKET=unix:///var/run/docker.sock

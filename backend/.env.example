# tailBale environment configuration
# Copy to .env and fill in your values.

# ── Auth ──────────────────────────────────────────────────────────────
# Secret key for signing JWT session tokens (REQUIRED in production).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-random-secret

# How long login sessions last (hours). Default: 24
JWT_EXPIRY_HOURS=24

# Set to true when running behind HTTPS (e.g. Tailscale HTTPS or reverse proxy)
COOKIE_SECURE=false

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Use "*" during development only.
CORS_ORIGINS=*

# ── Server ────────────────────────────────────────────────────────────
# Listen address and port
HOST=0.0.0.0
PORT=8080

# ── Paths ─────────────────────────────────────────────────────────────
# Directory for database, secrets, certs, generated configs, tailscale state.
# In Docker this is the mounted volume.
DATA_DIR=/data

# Docker socket path
DOCKER_SOCKET=unix:///var/run/docker.sock

# ── Domain & Services (also configurable via Setup wizard) ────────────
# BASE_DOMAIN=example.com
# ACME_EMAIL=you@example.com
# RECONCILE_INTERVAL_SECONDS=60
# CERT_RENEWAL_WINDOW_DAYS=30

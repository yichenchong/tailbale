# tailBale environment configuration
# Copy to .env and fill in your values.

# ── Auth ──────────────────────────────────────────────────────────────
# JWT signing secret is auto-generated on first startup and stored in
# DATA_DIR/secrets/.jwt_secret. No manual configuration needed.

# How long login sessions last (hours). Default: 24
JWT_EXPIRY_HOURS=24

# Set to true when running behind HTTPS (e.g. Tailscale HTTPS or reverse proxy)
COOKIE_SECURE=false

# Comma-separated allowed origins for split-origin deployments.
# Leave empty for same-origin/proxied deployments. Use "*" only for
# non-credentialed development requests; cookie auth requires explicit origins.
CORS_ORIGINS=

# ── Server ────────────────────────────────────────────────────────────
# Listen address and port
HOST=0.0.0.0
PORT=8080

# ── Paths ─────────────────────────────────────────────────────────────
# Directory for database, secrets, certs, generated configs, tailscale state.
# In Docker this is the mounted volume.
DATA_DIR=/data

# Docker socket path
DOCKER_SOCKET=unix:///var/run/docker.sock

# ── Bootstrap defaults ─────────────────────────────────────────────────
# Normal operation manages these through the setup wizard and settings API.
# Uncomment only to change first-boot defaults before the database is initialized.
# BASE_DOMAIN=example.com
# ACME_EMAIL=you@example.com
# RECONCILE_INTERVAL_SECONDS=60
# CERT_RENEWAL_WINDOW_DAYS=30
